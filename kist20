<script>
  // ── CANVAS PARTICLE SYSTEM ──────────────────────────────────────────
  const canvas = document.getElementById('hero-canvas');
  const ctx = canvas.getContext('2d');

  let W, H, mouse = { x: 0, y: 0 }, dpr = Math.min(window.devicePixelRatio || 1, 2);

  function resize() {
    W = canvas.width  = window.innerWidth  * dpr;
    H = canvas.height = window.innerHeight * dpr;
    ctx.scale(dpr, dpr);
  }
  resize();
  window.addEventListener('resize', () => { resize(); initParticles(); });

  // Track mouse for parallax
  window.addEventListener('mousemove', e => {
    mouse.x = (e.clientX / window.innerWidth  - 0.5);
    mouse.y = (e.clientY / window.innerHeight - 0.5);
  });

  // Parallax layers in hero — only move orb, rings keep CSS spin
  const heroOrb  = document.querySelector('.hero-orb');
  const heroNum  = document.querySelector('.hero-num');
  const heroBadge = document.querySelector('.hero-badge');
  function applyParallax() {
    if (heroOrb)   heroOrb.style.transform   = `translate(${mouse.x*18}px,${mouse.y*18}px) scale(1)`;
    if (heroNum)   heroNum.style.transform   = `translate(${mouse.x*6}px,${mouse.y*6}px)`;
    if (heroBadge) heroBadge.style.transform = `translate(${mouse.x*10}px,${mouse.y*10}px)`;
  }

  // ── PARTICLES ──
  const GOLD   = [201, 168,  76];
  const SILVER = [160, 170, 187];
  const WHITE  = [245, 238, 216];

  class Particle {
    constructor() { this.reset(true); }
    reset(init = false) {
      this.x  = Math.random() * window.innerWidth;
      this.y  = init ? Math.random() * window.innerHeight : window.innerHeight + 10;
      this.vx = (Math.random() - 0.5) * 0.3;
      this.vy = -(Math.random() * 0.4 + 0.1);
      this.size = Math.random() * 1.8 + 0.4;
      this.life = 0;
      this.maxLife = Math.random() * 300 + 200;
      const palette = [GOLD, SILVER, WHITE];
      this.color = palette[Math.floor(Math.random() * palette.length)];
      // some particles are "meteors" (long streaks)
      this.meteor = Math.random() < 0.06;
      if (this.meteor) {
        this.size = Math.random() * 1.2 + 0.6;
        this.vx = (Math.random() - 0.5) * 2;
        this.vy = -(Math.random() * 1.5 + 0.8);
        this.tail = [];
      }
      // some are "glints" (brief bright flashes)
      this.glint = !this.meteor && Math.random() < 0.1;
      this.glintPhase = Math.random() * Math.PI * 2;
    }
    update() {
      // gentle drift toward mouse (very subtle)
      this.vx += mouse.x * 0.002;
      this.vy += mouse.y * 0.002;
      // dampen
      this.vx *= 0.995;
      this.vy *= 0.998;

      if (this.meteor) {
        this.tail.push({ x: this.x, y: this.y });
        if (this.tail.length > 18) this.tail.shift();
      }

      this.x += this.vx;
      this.y += this.vy;
      this.life++;
      if (this.life > this.maxLife || this.y < -20 || this.x < -50 || this.x > window.innerWidth + 50) {
        this.reset();
      }
    }
    draw() {
      const prog = this.life / this.maxLife;
      let alpha = prog < 0.1 ? prog * 10 : prog > 0.8 ? (1 - prog) * 5 : 1;
      alpha = Math.min(alpha, 0.9);

      const [r, g, b] = this.color;

      if (this.glint) {
        // twinkle
        const tw = 0.5 + 0.5 * Math.sin(this.glintPhase + this.life * 0.08);
        alpha *= tw;
        const sz = this.size * (1 + tw * 1.5);
        // cross shape
        ctx.save();
        ctx.globalAlpha = alpha * 0.8;
        ctx.strokeStyle = `rgb(${r},${g},${b})`;
        ctx.lineWidth = 0.7;
        ctx.beginPath();
        ctx.moveTo(this.x - sz * 2.5, this.y);
        ctx.lineTo(this.x + sz * 2.5, this.y);
        ctx.moveTo(this.x, this.y - sz * 2.5);
        ctx.lineTo(this.x, this.y + sz * 2.5);
        ctx.stroke();
        ctx.restore();
      }

      if (this.meteor && this.tail.length > 2) {
        // draw tail
        for (let i = 0; i < this.tail.length - 1; i++) {
          const t = i / this.tail.length;
          ctx.beginPath();
          ctx.strokeStyle = `rgba(${r},${g},${b},${t * alpha * 0.5})`;
          ctx.lineWidth = this.size * t * 0.8;
          ctx.moveTo(this.tail[i].x, this.tail[i].y);
          ctx.lineTo(this.tail[i+1].x, this.tail[i+1].y);
          ctx.stroke();
        }
      }

      // main dot
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${r},${g},${b},${alpha * 0.75})`;
      ctx.fill();

      // soft glow for gold ones
      if (this.color === GOLD && alpha > 0.3) {
        const grd = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.size * 5);
        grd.addColorStop(0, `rgba(${r},${g},${b},${alpha * 0.15})`);
        grd.addColorStop(1, 'transparent');
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size * 5, 0, Math.PI * 2);
        ctx.fillStyle = grd;
        ctx.fill();
      }
    }
  }

  // ── CONSTELLATION LINES ──
  // occasional thin lines connecting nearby particles
  function drawConnections(particles) {
    const maxDist = 110;
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const d = Math.sqrt(dx*dx + dy*dy);
        if (d < maxDist) {
          const alpha = (1 - d / maxDist) * 0.08;
          ctx.beginPath();
          ctx.strokeStyle = `rgba(201,168,76,${alpha})`;
          ctx.lineWidth = 0.4;
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.stroke();
        }
      }
    }
  }

  let particles = [];
  function initParticles() {
    particles = Array.from({ length: 90 }, () => new Particle());
  }
  initParticles();

  // ── ANIMATION LOOP ──
  function animate() {
    ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);

    // very subtle background vignette
    const vig = ctx.createRadialGradient(
      window.innerWidth/2, window.innerHeight/2, window.innerHeight * 0.2,
      window.innerWidth/2, window.innerHeight/2, window.innerHeight * 0.9
    );
    vig.addColorStop(0, 'transparent');
    vig.addColorStop(1, 'rgba(6,13,31,0.4)');
    ctx.fillStyle = vig;
    ctx.fillRect(0, 0, window.innerWidth, window.innerHeight);

    // gold particles only for connections (first 60)
    const goldOnes = particles.filter(p => p.color === GOLD).slice(0, 30);
    drawConnections(goldOnes);

    particles.forEach(p => { p.update(); p.draw(); });

    applyParallax();
    requestAnimationFrame(animate);
  }
  animate();

  // ── SCROLL PROGRESS ──
  const bar = document.getElementById('progress-bar');
  window.addEventListener('scroll', () => {
    const h = document.documentElement;
    const pct = (window.scrollY / (h.scrollHeight - h.clientHeight)) * 100;
    bar.style.width = pct + '%';
  });

  // Sticky nav
  const nav = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  });

  // Reveal on scroll
  const revealEls = document.querySelectorAll('.reveal, .timeline-item');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('visible'), 
          e.target.classList.contains('timeline-item') ? i * 100 : 0);
      }
    });
  }, { threshold: 0.15 });
  revealEls.forEach(el => obs.observe(el));

  // Stagger grid children
  document.querySelectorAll('.docs-grid, .videos-grid, .about-stats').forEach(grid => {
    [...grid.children].forEach((child, i) => {
      child.style.transitionDelay = (i * 0.08) + 's';
    });
  });
</script>
